# Server
NODE_ENV=development
PORT=3300

# Azure AD / Entra ID
AZURE_CLIENT_ID=your-client-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-client-secret
REDIRECT_URI=http://localhost:3300/auth/callback

# Database
DATABASE_URL=postgres://paperclip:paperclip@127.0.0.1:54329/paperclip

# JWT
JWT_SECRET=your-secure-jwt-secret
JWT_EXPIRES_IN=24h

# SharePoint
SHAREPOINT_SITE_URL=https://rebelgroup.sharepoint.com/sites/AI
SHAREPOINT_DRIVE_ID=

# Frontend
FRONTEND_URL=http://localhost:3400
