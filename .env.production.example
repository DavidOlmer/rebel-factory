# ============================================
# Rebel AI Factory - Production Environment
# ============================================
# Copy to .env for production deployment
# NEVER commit actual credentials to version control!

# --------------------------------------------
# Server
# --------------------------------------------
NODE_ENV=production
PORT=3300

# --------------------------------------------
# Database (Required)
# --------------------------------------------
# Format: postgres://user:password@host:port/database?sslmode=require
# 
# For Render.com:
#   Use the Internal Database URL from your Render dashboard
#
# For Azure Database for PostgreSQL:
#   postgres://user@server:password@server.postgres.database.azure.com:5432/rebel_factory?sslmode=require
#
# For AWS RDS:
#   postgres://user:password@instance.region.rds.amazonaws.com:5432/rebel_factory?sslmode=require
#
DATABASE_URL=postgres://user:pass@host:5432/rebel_factory?sslmode=require

# --------------------------------------------
# Azure AD / Entra ID (Required)
# --------------------------------------------
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret

# OAuth callback - must match Azure AD app registration
REDIRECT_URI=https://your-domain.com/auth/callback

# --------------------------------------------
# JWT Authentication (Required)
# --------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=generate-a-secure-random-string-at-least-64-bytes
JWT_EXPIRES_IN=24h

# --------------------------------------------
# Frontend CORS
# --------------------------------------------
FRONTEND_URL=https://your-domain.com

# --------------------------------------------
# SharePoint Integration (Optional)
# --------------------------------------------
SHAREPOINT_SITE_URL=https://rebelgroup.sharepoint.com/sites/AI
SHAREPOINT_DRIVE_ID=

# --------------------------------------------
# Rate Limiting
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------
# Logging
# --------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# --------------------------------------------
# IMPORTANT: Production Security
# --------------------------------------------
# - Never set DEV_AUTH_BYPASS=true in production
# - Use strong, unique JWT_SECRET (64+ characters)
# - Rotate AZURE_CLIENT_SECRET before expiry
# - Enable Azure AD Conditional Access
# - Use HTTPS only (enforce in load balancer)
